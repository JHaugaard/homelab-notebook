# =============================================================================
# Homelab Notebook - Environment Variables
# =============================================================================
# Copy this file to .env.local (development) or .env (production)
# NEVER commit .env.local or .env files to git!

# =============================================================================
# Supabase Configuration (Remote - VPS8)
# =============================================================================
# Get these from your Supabase dashboard: Settings > API

# Public URL - safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://supabase.haugaard.dev

# Anon key - safe to expose to browser (RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - SERVER ONLY, never expose to client
# Has full database access, bypasses RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# Backblaze B2 Storage (Optional - for large file storage)
# =============================================================================
# Get these from Backblaze B2: App Keys > Add a New Application Key

# B2 Application Key ID
B2_APPLICATION_KEY_ID=your-key-id-here

# B2 Application Key (secret)
B2_APPLICATION_KEY=your-application-key-here

# B2 Bucket Name
B2_BUCKET_NAME=your-bucket-name

# B2 S3-compatible endpoint (varies by region)
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# =============================================================================
# Ollama Configuration (Remote - VPS8)
# =============================================================================
# Base URL for Ollama API
OLLAMA_BASE_URL=https://ollama.haugaard.dev

# Default model for auto-tagging (optional, defaults to llama3.2:3b)
OLLAMA_MODEL=llama3.2:3b

# Embedding model for semantic search (optional, for v2)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# Application Configuration
# =============================================================================
# Public app URL (used for OAuth callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Development Settings (optional)
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=debug

# Node environment (set automatically by Next.js)
# NODE_ENV=development

# =============================================================================
# Production Settings (VPS2 only)
# =============================================================================
# Uncomment and set these for production deployment:

# NEXT_PUBLIC_APP_URL=https://notebook.haugaard.dev
# LOG_LEVEL=info
# NODE_ENV=production
